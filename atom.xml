    <title>用Dockerfile製作一份映像檔來啟動Python服務吧</title>
    <link href="https://cody-kao.github.io/Docker/%E7%94%A8Dockerfile%E8%A3%BD%E4%BD%9C%E4%B8%80%E4%BB%BD%E6%98%A0%E5%83%8F%E6%AA%94%E4%BE%86%E5%95%9F%E5%8B%95Python%E6%9C%8D%E5%8B%99%E5%90%A7/"/>
    <id>https://cody-kao.github.io/Docker/%E7%94%A8Dockerfile%E8%A3%BD%E4%BD%9C%E4%B8%80%E4%BB%BD%E6%98%A0%E5%83%8F%E6%AA%94%E4%BE%86%E5%95%9F%E5%8B%95Python%E6%9C%8D%E5%8B%99%E5%90%A7/</id>
    <published>2026-01-21T11:42:59.000Z</published>
